{% extends "base.html.j2" %}
{% block body_class %}resume-page{% endblock %}

{% block body %}
<main class="resume-sheet">
  <header class="resume-header" id="resume">
    <div>
      <p class="eyebrow">Resume / Portfolio Main Page</p>
      <h1>{{ personal.display_name | default(site.name) }}</h1>
      <h2>{{ site.title }}</h2>
      <p class="headline">{{ site.headline }}</p>
      <p class="one-liner">{{ site.one_liner }}</p>
    </div>
    <div class="contact-box">
      <div>{{ personal.location }}</div>
      <div>{{ personal.email }}</div>
      <div>{{ personal.phone }}</div>
      <div><a href="{{ personal.linkedin.url }}" target="_blank">{{ personal.linkedin.label }}</a></div>
      <div><a href="{{ personal.github.url }}" target="_blank">{{ personal.github.label }}</a></div>
      {% for link in personal.optional_links %}
      {% if link.url %}
      <div><a href="{{ link.url }}" target="_blank">{{ link.label }}</a></div>
      {% endif %}
      {% endfor %}
    </div>
  </header>

  <section class="keyword-strip">
    {% for keyword in site.keywords %}
    <span>{{ keyword }}</span>
    {% endfor %}
  </section>

  <section class="notion-block">
    <h3>Core Positioning</h3>
    <ul class="tight-list">
      {% for item in site.main_focus %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </section>

  <section class="two-col">
    <div class="notion-block">
      <h3>Education</h3>
      {% for edu in resume.education %}
      <div class="mini-entry">
        <strong>{{ edu.institute }}</strong>
        <span>{{ edu.degree }} | {{ edu.period }}</span>
        {% if edu.thesis %}
        <em>Thesis: {{ edu.thesis }}</em>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <div class="notion-block">
      <h3>Skill Stack</h3>
      <p><strong>Control:</strong> {{ resume.skills.control | join(" · ") }}</p>
      <p><strong>Validation:</strong> {{ resume.skills.validation | join(" · ") }}</p>
      <p><strong>Software:</strong> {{ resume.skills.software | join(" · ") }}</p>
    </div>
  </section>

  <section class="notion-block" id="experience">
    <h3>Experience</h3>
    <div class="experience-list">
      {% for exp in experiences %}
      <article class="experience-card">
        <div class="entry-top">
          <div>
            <strong>{{ exp.role }}</strong>
            <span>{{ exp.organization }} | {{ exp.period }}</span>
          </div>
          <a href="{{ exp.detail_output }}" class="detail-link no-print">Detail</a>
        </div>
        <p class="hook">{{ exp.hook }}</p>
        <ul>
          {% for bullet in exp.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        <p class="print-url print-only">Detail: {{ exp.detail_output }}</p>
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="narrative-block" id="narrative">
    <h3>{{ narrative.title }}</h3>
    <p>{{ narrative.intro }}</p>
    <ul>
      {% for item in narrative['items'] %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </section>

  <section class="notion-block" id="toolchains">
    <h3>Selected Toolchain Projects</h3>
    <p class="section-note">Main-root vehicle projects are covered in Experience. This section highlights independently built toolchains that removed team bottlenecks.</p>
    <div class="toolchain-list">
      {% for project in toolchains %}
      <article class="toolchain-card">
        <div class="entry-top">
          <div>
            <strong>{{ project.title }}</strong>
            <span>{{ project.stack }}</span>
          </div>
          <div class="entry-actions no-print">
            <a href="{{ project.detail_output }}" class="detail-link">Detail</a>
            {% if project.mock_output %}
            <a href="{{ project.mock_output }}" class="detail-link mock-link">MOCK</a>
            {% endif %}
          </div>
        </div>
        <p class="hook">{{ project.hook }}</p>
        <div class="objective-impact">
          <p><b>Objective:</b> {{ project.objective }}</p>
          <p><b>Impact:</b> {{ project.impact }}</p>
        </div>
        <div class="tag-row">
          {% for tag in project.tags %}
          <span>{{ tag }}</span>
          {% endfor %}
        </div>
        <p class="print-url print-only">Detail: {{ project.detail_output }}</p>
        {% if project.mock_output %}
        <p class="print-url print-only">Mock: {{ project.mock_output }}</p>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="footer-cta">
    <strong>Full technical website:</strong>
    <span><a href="{{ personal.portfolio.url }}" target="_blank">{{ personal.portfolio.url }}</a></span>
    <p>Use this resume-style page for PDF export. Use detail pages for architecture diagrams, screenshots, evidence, and deeper engineering explanations.</p>
  </section>
</main>
{% endblock %}

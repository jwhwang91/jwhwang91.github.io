{% extends "base.html.j2" %}
{% block body_class %}resume-page{% endblock %}
{% block body %}
<main class="resume-sheet" id="resume">
  <header class="resume-header">
    <div>
      <div class="eyebrow">Resume / Portfolio Main Page</div>
      <h1>{{ personal.display_name | default(site.name) }}</h1>
      <h2>{{ site.title }}</h2>
      <p class="headline">{{ site.headline }}</p>
      <p class="one-liner">{{ site.one_liner }}</p>
    </div>
    <aside class="contact-box" aria-label="Contact information">
      {% if personal.location %}<div>{{ personal.location }}</div>{% endif %}
      {% if personal.email %}<div><a href="mailto:{{ personal.email }}">{{ personal.email }}</a></div>{% endif %}
      {% if personal.phone %}<div>{{ personal.phone }}</div>{% endif %}
      {% if personal.linkedin.url %}
        <div><a href="{{ personal.linkedin.url }}" target="_blank" rel="noopener noreferrer">{{ personal.linkedin.label }}</a></div>
      {% endif %}
      {% if personal.github.url %}
        <div><a href="{{ personal.github.url }}" target="_blank" rel="noopener noreferrer">{{ personal.github.label }}</a></div>
      {% endif %}
      {% for link in personal.optional_links %}
        {% if link.url %}
          <div><a href="{{ link.url }}" target="_blank" rel="noopener noreferrer">{{ link.label }}</a></div>
        {% endif %}
      {% endfor %}
    </aside>
  </header>

  {% if site.keywords %}
  <section class="keyword-strip" aria-label="Target roles and keywords">
    {% for keyword in site.keywords %}
      <span>{{ keyword }}</span>
    {% endfor %}
  </section>
  {% endif %}

  {% if site.main_focus %}
  <section class="notion-block">
    <h3>Professional Summary</h3>
    <ul class="tight-list">
      {% for item in site.main_focus %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <section class="notion-block">
    <h3>Core Competencies</h3>
    {% if resume.skills.control %}
      <p><strong>Control:</strong> {{ resume.skills.control | join(" / ") }}</p>
    {% endif %}
    {% if resume.skills.validation %}
      <p><strong>Validation:</strong> {{ resume.skills.validation | join(" / ") }}</p>
    {% endif %}
    {% if resume.skills.software %}
      <p><strong>Software:</strong> {{ resume.skills.software | join(" / ") }}</p>
    {% endif %}
    {% if resume.skills.qualifications %}
      <p><strong>Qualifications:</strong> {{ resume.skills.qualifications | join(" / ") }}</p>
    {% endif %}
  </section>

  <section class="notion-block" id="experience">
    <h3>Professional Experience</h3>
    <div class="experience-list">
      {% for exp in experiences %}
      <article class="experience-card">
        <div class="entry-top">
          <div>
            <strong>{{ exp.role }}</strong>
            <span>{{ exp.organization }} | {{ exp.period }}</span>
          </div>
          {% if exp.detail_output %}
          <div class="entry-actions no-print">
            <a class="detail-link" href="{{ exp.detail_output }}">Technical Case Study</a>
          </div>
          {% endif %}
        </div>
        {% if exp.hook %}<p class="hook">{{ exp.hook }}</p>{% endif %}
        {% if exp.bullets %}
        <ul>
          {% for bullet in exp.bullets %}
            <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
        {% if exp.detail_output %}
          <p class="print-only">Detail: {{ exp.detail_output }}</p>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="narrative-block" id="toolchains">
    <h3>Selected Technical Projects</h3>
    <p class="section-note">Public-safe technical case studies for validation tooling, AI-transition prototypes, and commercial-vehicle ADAS debugging workflows.</p>
    <div class="toolchain-list">
      {% for project in toolchains %}
      <article class="toolchain-card">
        <div class="entry-top">
          <div>
            <strong>{{ project.title }}</strong>
            <span>{{ project.stack }}</span>
          </div>
          <div class="entry-actions no-print">
            {% if project.detail_output %}
              <a class="detail-link" href="{{ project.detail_output }}">Technical Case Study</a>
            {% endif %}
            {% if project.repo_url %}
              <a class="detail-link mock-link" href="{{ project.repo_url }}" target="_blank" rel="noopener noreferrer">GitHub</a>
            {% endif %}
          </div>
        </div>
        {% if project.hook %}<p class="hook">{{ project.hook }}</p>{% endif %}
        <div class="objective-impact">
          {% if project.objective %}<p><strong>Objective:</strong> {{ project.objective }}</p>{% endif %}
          {% if project.impact %}<p><strong>Impact:</strong> {{ project.impact }}</p>{% endif %}
        </div>
        {% if project.tags %}
        <div class="tag-row">
          {% for tag in project.tags %}
            <span>{{ tag }}</span>
          {% endfor %}
        </div>
        {% endif %}
        <div class="print-only">
          {% if project.detail_output %}<p>Detail: {{ project.detail_output }}</p>{% endif %}
          {% if project.repo_url %}<p>GitHub: {{ project.repo_url }}</p>{% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </section>

  {% if resume.education %}
  <section class="notion-block">
    <h3>Education</h3>
    <div class="two-col">
      {% for edu in resume.education %}
      <div class="mini-entry">
        <strong>{{ edu.institute }}</strong>
        <span>{{ edu.degree }} | {{ edu.period }}</span>
        {% if edu.location %}<span>{{ edu.location }}</span>{% endif %}
        {% if edu.thesis %}<em>Thesis: {{ edu.thesis }}</em>{% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <section class="footer-cta">
    <strong>Links:</strong>
    {% if personal.portfolio.url %}
      <span><a href="{{ personal.portfolio.url }}" target="_blank" rel="noopener noreferrer">{{ personal.portfolio.url }}</a></span>
    {% endif %}
    {% if personal.github.url %}
      <span><a href="{{ personal.github.url }}" target="_blank" rel="noopener noreferrer">{{ personal.github.label }}</a></span>
    {% endif %}
    <p>Use this resume-style page for PDF export. Use detail pages for public-safe technical case studies and sanitized engineering notes.</p>
  </section>
</main>
{% endblock %}
